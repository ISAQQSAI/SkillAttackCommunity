generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
}

enum SubmissionStatus {
  uploaded
  parsing
  preview_ready
  parse_failed
  submitted
  under_review
  rejected
  approved
  published
}

enum SubmissionSource {
  web
  api
}

enum ArtifactKind {
  original_bundle
  report_json
  skill_archive
  metadata
}

enum ArtifactVisibility {
  admin_only
  preview_only
  public_case
}

enum ReviewAction {
  submitted
  under_review
  rejected
  approved
  published
  unpublished
  note
}

model User {
  id            String         @id @default(cuid())
  githubId      String?        @unique
  githubLogin   String?        @unique
  name          String
  email         String?
  image         String?
  role          UserRole       @default(admin)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  reviews       ReviewRecord[] @relation("ReviewerRecords")
  publishedCases PublicCase[]  @relation("PublisherCases")
}

model Submission {
  id               String            @id @default(cuid())
  publicId         String            @unique @default(cuid())
  status           SubmissionStatus  @default(uploaded)
  source           SubmissionSource  @default(web)
  originalFilename String
  contentType      String
  sizeBytes        Int
  storageKey       String
  sha256           String
  previewTokenHash String
  trackingTokenHash String?
  parserVersion    String            @default("skillattack-report-bundle-v1")
  parseError       String?
  bundleMeta       Json?
  parsedIndex      Json?
  previewPayload   Json?
  summaryStats     Json?
  redactionSummary Json?
  submitterLabel   String?
  contactEmail     String?
  submissionNotes  String?
  adminNotes       String?
  verificationSummary String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  previewReadyAt   DateTime?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  publishedAt      DateTime?

  findings         SubmissionFinding[]
  artifacts        SubmissionArtifact[]
  reviews          ReviewRecord[]
  publicCase       PublicCase?

  @@index([status, updatedAt])
  @@index([submittedAt])
}

model SubmissionFinding {
  id                   String      @id @default(cuid())
  submissionId         String
  sortOrder            Int
  reportPath           String?
  reportSkillId        String
  sourceLink           String?
  skillHash            String?
  findingKey           String
  harmType             String
  vulnerabilitySurface String
  provider             String?
  model                String?
  verdict              String?
  reasonCode           String?
  confidence           Float?
  harmfulPromptPreview String
  smokingGunPreview    String?
  evidenceSummaryPreview String?
  finalResponsePreview String?
  redactionFlags       Json?
  judgeSummary         Json?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  submission           Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, sortOrder])
  @@index([reportSkillId])
}

model SubmissionArtifact {
  id            String             @id @default(cuid())
  submissionId  String
  kind          ArtifactKind
  visibility    ArtifactVisibility @default(admin_only)
  fileName      String
  pathInBundle  String?
  storageKey    String
  contentType   String
  sizeBytes     Int
  sha256        String?
  redactionFlags Json?
  previewText   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  submission    Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, kind])
}

model ReviewRecord {
  id            String           @id @default(cuid())
  submissionId  String
  reviewerId    String
  action        ReviewAction
  statusBefore  SubmissionStatus?
  statusAfter   SubmissionStatus
  notes         String?
  payload       Json?
  createdAt     DateTime         @default(now())

  submission    Submission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer      User             @relation("ReviewerRecords", fields: [reviewerId], references: [id])

  @@index([submissionId, createdAt])
}

model PublicCase {
  id            String      @id @default(cuid())
  submissionId  String      @unique
  slug          String      @unique
  title         String
  summary       String
  payload       Json
  publishedById String
  publishedAt   DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  submission    Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  publishedBy   User        @relation("PublisherCases", fields: [publishedById], references: [id])
}
