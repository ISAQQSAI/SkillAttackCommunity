generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
}

enum SubmissionStatus {
  submitted
  under_review
  rejected
  published
}

enum SubmissionSource {
  web
  api
}

enum ArtifactKind {
  original_bundle
  report_json
  skill_archive
  metadata
}

enum ArtifactVisibility {
  admin_only
  public_case
}

enum ReviewAction {
  submitted
  under_review
  rejected
  published
  note
}

model User {
  id            String         @id @default(cuid())
  githubId      String?        @unique
  githubLogin   String?        @unique
  name          String
  email         String?
  image         String?
  role          UserRole       @default(admin)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  reviews       ReviewRecord[] @relation("ReviewerRecords")
  publishedCases PublicCase[]  @relation("PublisherCases")
}

model Submission {
  id               String            @id @default(cuid())
  publicId         String            @unique @default(cuid())
  status           SubmissionStatus  @default(submitted)
  source           SubmissionSource  @default(web)
  parsedBundleId   String
  originalFilename String
  contentType      String
  sizeBytes        Int
  submitterLabel   String?
  contactEmail     String?
  submissionNotes  String?
  adminNotes       String?
  verificationSummary String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  submittedAt      DateTime?
  reviewedAt       DateTime?
  publishedAt      DateTime?

  parsedBundle     ParsedBundle      @relation(fields: [parsedBundleId], references: [id], onDelete: Restrict)
  reviews          ReviewRecord[]
  publicCase       PublicCase?

  @@index([status, updatedAt])
  @@index([submittedAt])
  @@index([parsedBundleId])
}

model ParsedBundle {
  id               String               @id @default(cuid())
  sha256           String
  parserVersion    String               @default("skillatlas-submission-v2")
  storageKey       String
  parseError       String?
  bundleMeta       Json?
  parsedIndex      Json?
  displayPayload   Json?
  summaryStats     Json?
  redactionSummary Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  submissions      Submission[]
  findings         ParsedBundleFinding[]
  artifacts        ParsedBundleArtifact[]

  @@unique([sha256, parserVersion])
}

model ParsedBundleFinding {
  id                   String      @id @default(cuid())
  parsedBundleId       String
  sortOrder            Int
  reportPath           String?
  reportSkillId        String
  sourceLink           String?
  skillHash            String?
  findingKey           String
  harmType             String
  vulnerabilitySurface String
  provider             String?
  model                String?
  verdict              String?
  reasonCode           String?
  confidence           Float?
  harmfulPromptPreview String
  smokingGunPreview    String?
  evidenceSummaryPreview String?
  finalResponsePreview String?
  redactionFlags       Json?
  judgeSummary         Json?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  parsedBundle         ParsedBundle  @relation(fields: [parsedBundleId], references: [id], onDelete: Cascade)

  @@index([parsedBundleId, sortOrder])
  @@index([reportSkillId])
}

model ParsedBundleArtifact {
  id            String             @id @default(cuid())
  parsedBundleId String
  kind          ArtifactKind
  visibility    ArtifactVisibility @default(admin_only)
  fileName      String
  pathInBundle  String?
  storageKey    String
  contentType   String
  sizeBytes     Int
  sha256        String?
  redactionFlags Json?
  previewText   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  parsedBundle  ParsedBundle       @relation(fields: [parsedBundleId], references: [id], onDelete: Cascade)

  @@index([parsedBundleId, kind])
}

model ReviewRecord {
  id            String           @id @default(cuid())
  submissionId  String
  reviewerId    String
  action        ReviewAction
  statusBefore  SubmissionStatus?
  statusAfter   SubmissionStatus
  notes         String?
  payload       Json?
  createdAt     DateTime         @default(now())

  submission    Submission       @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer      User             @relation("ReviewerRecords", fields: [reviewerId], references: [id])

  @@index([submissionId, createdAt])
}

model PublicCase {
  id            String      @id @default(cuid())
  submissionId  String      @unique
  slug          String      @unique
  title         String
  summary       String
  payload       Json
  publishedById String
  publishedAt   DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  submission    Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  publishedBy   User        @relation("PublisherCases", fields: [publishedById], references: [id])
}
